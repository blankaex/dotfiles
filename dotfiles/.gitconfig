[user]
    name = blankaex
    email = blankaex@protonmail.com
    username = blankaex
[credential]
    helper = cache --timeout 3600
[pull]
    rebase = false
[init]
	defaultBranch = master
[core]
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    dark = true
[merge]
    conflictStyle = zdiff3
